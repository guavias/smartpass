BASE_URL=http://localhost:8000
PORTAL_BASE_URL=http://localhost:8000

# MongoDB
MONGODB_URL=mongodb+srv://<db_user>:<db_password>@<cluster>/<db_name>?retryWrites=true&w=majority
MONGODB_DB_NAME=smartpass

# Square
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=<square_access_token>
SQUARE_LOCATION_ID=<square_location_id>
SQUARE_API_VERSION=2024-10-17

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=you@gmail.com

# Rotating QR signing secret
QR_SIGNING_SECRET=<long_random_secret>

# Optional server config
HOST=127.0.0.1
PORT=8000
UVICORN_RELOAD=true

# Admin auth seed (stored in MongoDB at startup when ADMIN_SEED_ON_STARTUP=true)
ADMIN_SEED_ON_STARTUP=true
ADMIN_EMAIL=admin@smartpass.dev
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=SmartPass Admin
ADMIN_ROLE=admin
ADMIN_ID=admin-local-1
ADMIN_TOKEN_EXPIRES_IN=3600
